# ─── Authentication ───────────────────────────────────────────────────────────
# Generate a random secret: https://generate-secret.vercel.app/32 or `openssl rand -base64 32`
AUTH_SECRET=****

# ─── AI Gateway ──────────────────────────────────────────────────────────────
# Required for non-Vercel deployments (Vercel uses OIDC automatically)
# https://vercel.com/ai-gateway
AI_GATEWAY_API_KEY=****

# ─── Storage ─────────────────────────────────────────────────────────────────
# https://vercel.com/docs/vercel-blob
BLOB_READ_WRITE_TOKEN=****

# https://vercel.com/docs/postgres
POSTGRES_URL=****

# https://vercel.com/docs/redis (optional — enables stream resumption)
REDIS_URL=****

# ─── App Configuration ──────────────────────────────────────────────────────
# Set to "/demo" for demo deployments, leave empty for standard deployment
# NEXT_PUBLIC_BASE_PATH=

# Set to "1" to enable demo mode with base path
# IS_DEMO=0

# Local-first default: blocks cloud model calls unless a local provider is configured.
# Set to "0" to allow the Vercel AI Gateway / direct provider keys.
IRIS_LOCAL_ONLY=1

# ─── Local AI provider (Ollama) ─────────────────────────────────────────────
# Used when IRIS_LOCAL_ONLY=1 (or when explicitly preferred).
# Default base URL is http://localhost:11434/v1 (Ollama's OpenAI-compatible API).
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_DEFAULT_MODEL=llama3

# ─── Sovereign Hub Mode ─────────────────────────────────────────────────────
# When "1", Iris exposes a local federation endpoint so other Iris instances
# on the same network can use this one as a memory/skill peer.
# See docs/sovereign-hub.md.
# IRIS_HUB_MODE=0

# ─── Integrations (optional) ────────────────────────────────────────────────
# MemPalace MCP server command — enables palace memory tools
# https://github.com/ljbudgie/mempalace
# MEMPALACE_MCP_COMMAND="python -m mempalace.mcp_server"
